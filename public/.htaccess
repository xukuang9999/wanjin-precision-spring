DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteCond %{HTTP_HOST} ^www\.wanjinspring\.com$ [NC]
  RewriteRule ^ https://wanjinspring.com%{REQUEST_URI} [R=301,L]

  RewriteRule ^index\.html$ - [L]
  RewriteRule ^assets/ - [L]
  RewriteRule ^factory/ - [L]
  RewriteRule ^products/.*\.(jpg|jpeg|png|webp|avif|svg)$ - [L,NC]
  RewriteRule ^(robots\.txt|sitemap\.xml|blog-feed\.xml|blog-feed\.json|llms\.txt|llms-full\.txt|.*\.json|favicon\.ico)$ - [L,NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
